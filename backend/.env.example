# ============================================
# CONFIGURAÇÃO DO BACKEND — Sistema Escolar
# ============================================
# 1. Copie este arquivo para: backend/.env
# 2. Preencha os valores reais
# 3. NUNCA commite o .env real no git (já está no .gitignore)
#
# NOTA DE SEGURANÇA: todos os valores abaixo ficam propositalmente VAZIOS.
# Placeholders com formato de credencial real (prefixos re_, sk_, AIza,
# usuario:senha@host) disparam scanners de vazamento como o GitGuardian.

# ============================================
# BANCO DE DADOS (MongoDB Atlas) — OBRIGATÓRIO
# ============================================
# Obtenha em: MongoDB Atlas → Connect → Drivers → Copy connection string
MONGODB_URI=
MONGODB_DB_NAME=test

# ============================================
# SERVIDOR
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# SEGURANÇA — OBRIGATÓRIAS EM PRODUÇÃO
# ============================================
# Gere cada uma com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
SESSION_SECRET=

# ============================================
# URL DO FRONTEND (CORS e links de e-mail)
# ============================================
# Em produção, defina a URL completa onde o frontend está hospedado
FRONTEND_URL=http://localhost:3001

# ============================================
# GOOGLE OAUTH (login com Google no portal) — opcional
# ============================================
# Client ID criado em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# ============================================
# E-MAIL / SMTP (recuperação de senha, notificações) — opcional
# ============================================
# Provedor padrão: Resend (smtp.resend.com). Para Gmail, use smtp.gmail.com
# com senha de app (não a senha da conta).
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=

# ============================================
# TTS / IA — PROVEDORES DE VOZ E TEXTO — opcionais
# ============================================
# Gemini: https://aistudio.google.com/app/apikey
GOOGLE_TTS_API_KEY=
# ElevenLabs: https://elevenlabs.io → Profile Settings → API Key
ELEVENLABS_API_KEY=

# ============================================
# OBSERVABILIDADE — opcional
# ============================================
# Se definido, GET /api/metrics em produção exige Authorization: Bearer <token>
METRICS_TOKEN=
