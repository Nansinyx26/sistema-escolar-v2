# ============================================
# CONFIGURAÇÃO DO BACKEND — Sistema Escolar
# ============================================
# 1. Copie este arquivo para: backend/.env
# 2. Preencha os valores reais
# 3. NUNCA commite o .env real no git (já está no .gitignore)

# ============================================
# BANCO DE DADOS (MongoDB Atlas)
# ============================================
# Obtenha em: MongoDB Atlas → Connect → Drivers → Copy connection string
MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=escola_db

# ============================================
# SERVIDOR
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# SEGURANÇA — JWT
# ============================================
# OBRIGATÓRIO em produção! Gere com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UMA_STRING_LONGA_E_ALEATORIA

# ============================================
# URL DO FRONTEND (CORS e links de e-mail)
# ============================================
# Em produção, defina a URL completa onde o frontend está hospedado
FRONTEND_URL=http://localhost:3001

# ============================================
# E-MAIL (Recuperação de Senha)
# ============================================
# Provedor padrão: Resend (smtp.resend.com). Para Gmail, defina EMAIL_HOST=smtp.gmail.com
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=465
EMAIL_USER=resend
EMAIL_PASS=re_SUA_API_KEY_AQUI
