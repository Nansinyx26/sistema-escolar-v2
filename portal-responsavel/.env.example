# Variáveis de ambiente para o Portal do Responsável
# Copie este arquivo como .env e preencha com seus valores reais.

# URL base da API do backend (sem /api no final)
# Desenvolvimento local:
VITE_API_URL=http://localhost:3001/api

# Produção (Render):
# VITE_API_URL=https://sistema-escolar-bfty.onrender.com/api

# Google OAuth 2.0 Client ID (opcional – apenas se usar login via Gmail)
VITE_GMAIL_CLIENT_ID=seu_client_id.apps.googleusercontent.com
VITE_GMAIL_REDIRECT_URI=http://localhost:5174/auth/callback

# Email da diretoria para confirmações de leitura (opcional)
VITE_DIRECTOR_EMAIL=direcao@escolajaguari.edu.br
