# Variáveis de ambiente para o Portal do Responsável
# Copie este arquivo como .env e preencha com seus valores reais.

# URL base da API do backend (com /api no final)
# Desenvolvimento local:
VITE_API_URL=http://localhost:3001/api

# Produção (Render):
# VITE_API_URL=https://sistema-escolar-bfty.onrender.com/api

# Google OAuth 2.0 Client ID (obrigatório para login com Google)
# Obtenha em: https://console.cloud.google.com/apis/credentials
VITE_GMAIL_CLIENT_ID=SEU_CLIENT_ID_AQUI

# Compatibilidade com versões anteriores (opcional — VITE_GMAIL_CLIENT_ID tem prioridade)
# VITE_GOOGLE_CLIENT_ID=

# Email da diretoria para confirmações de leitura (opcional)
VITE_DIRECTOR_EMAIL=direcao@escolajaguari.edu.br
