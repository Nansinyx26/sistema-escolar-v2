# ============================================
# CONFIGURAÇÃO MONGODB ATLAS
# ============================================
# O arquivo de configuração completo do backend fica em: backend/.env.example
#
# NOTA DE SEGURANÇA: valores propositalmente vazios — exemplos com formato
# de credencial real (usuario:senha@host) disparam scanners de vazamento.

# Connection String do MongoDB Atlas
# Obtenha em: MongoDB Atlas → Connect → Drivers → Copy connection string
MONGODB_URI=

# Nome do banco de dados
MONGODB_DB_NAME=test

# ============================================
# PARA DESENVOLVIMENTO LOCAL (OPCIONAL)
# ============================================
# MONGODB_URI=mongodb://localhost:27017/escola_db

# ============================================
# INSTRUÇÕES
# ============================================
# 1. Copie este arquivo para: .env (na pasta backend/)
# 2. Preencha os valores reais
# 3. Nunca compartilhe o .env preenchido (já está no .gitignore)
