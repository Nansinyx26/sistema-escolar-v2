# ============================================
# CONFIGURAÇÃO MONGODB ATLAS
# ============================================

# Connection String do MongoDB Atlas
# Substitua os valores entre < > pelos seus dados reais
MONGODB_URI=REMOVIDO_POR_SEGURANCA

# Nome do banco de dados
MONGODB_DB_NAME=test

# ============================================
# EXEMPLO DE CONNECTION STRING
# ============================================
# MONGODB_URI=REMOVIDO_POR_SEGURANCA

# ============================================
# PARA DESENVOLVIMENTO LOCAL (OPCIONAL)
# ============================================
# MONGODB_URI=mongodb://localhost:27017/escola_db

# ============================================
# INSTRUÇÕES
# ============================================
# 1. Renomeie este arquivo para: .env
# 2. Substitua <usuario>, <senha> e <cluster> pelos seus dados
# 3. Nunca compartilhe este arquivo (já está no .gitignore)
# 4. Para obter a connection string:
#    - MongoDB Atlas → Connect → Drivers → Copy connection string
